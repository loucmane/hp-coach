    "drizzle-orm": "^0.45.2",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "19",
    "react-dom": "19",
    "react-katex": "^3.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sqlocal": "^0.18.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
