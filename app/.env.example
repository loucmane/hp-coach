# Copy to .env.local (gitignored) and fill in real values.
# VITE_-prefixed vars are exposed to the client bundle by design — only
# put values that are safe to publish (e.g. publishable keys, URLs).
# Secret keys (sk_…) must NEVER live here; they belong in
# `worker/.dev.vars` for local dev or `wrangler secret put` for staging/prod.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
VITE_API_BASE_URL=http://localhost:8787
