# Copy to .env.local (gitignored) and fill in real values.
# VITE_-prefixed vars are exposed to the client bundle by design — only
# put values that are safe to publish (e.g. publishable keys, URLs).
# Secret keys (sk_…) must NEVER live here; they belong in
# `worker/.dev.vars` for local dev or `wrangler secret put` for staging/prod.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
VITE_API_BASE_URL=http://localhost:8787

# Strict-tier content source. LEAVE UNSET for local dev, vitest, and
# Playwright e2e — the question bank (/data) and explanations
# (/explanations) are served as local static assets exactly as before,
# zero extra setup. Set to "true" ONLY for staging/production builds
# (the deploy workflow sets it): the corpus is then excluded from the
# Pages bundle and fetched auth-gated from R2 via the worker's
# /api/content route. See app/src/data/contentSource.ts.
# VITE_CONTENT_FROM_API=true

# Server-only — read by Playwright's Clerk fixture (and any other test
# tooling). NEVER prefix with VITE_ — that would bundle it to the client.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Email used for test sign-ins. The `+clerk_test@…` token tells Clerk
# (in dev instances) to short-circuit OTP verification with code 424242.
E2E_TEST_EMAIL=hpc-e2e+clerk_test@example.com
