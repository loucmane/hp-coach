{
  "name": "hpfetcher",
  "private": true,
  "version": "0.0.0",
  "description": "HP-Coach repo root — owns git hooks for the app/ workspace.",
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "app/src/**/*.{ts,tsx,js,jsx,json}": [
      "pnpm --dir app exec biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
